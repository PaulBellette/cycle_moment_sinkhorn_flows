@article{CHEN2019119,
  title = {Birkhoff-von Neumann theorem and decomposition for doubly stochastic tensors},
  journal = {Linear Algebra and its Applications},
  volume = {583},
  pages = {119-133},
  year = {2019},
  issn = {0024-3795},
  doi = {https://doi.org/10.1016/j.laa.2019.08.027},
  url = {https://www.sciencedirect.com/science/article/pii/S002437951930374X},
  author = {Haibin Chen and Liqun Qi and Louis Caccetta and Guanglu Zhou},
  keywords = {Nonnegative tensor, Doubly stochastic tensor, Birkhoff-von Neumann theorem, Extreme point},
  abstract = {The well-known Birkhoff-von Neumann theorem states that a doubly stochastic matrix is a convex combination of permutation matrices. In this paper, we present a new concept for doubly stochastic tensors and study a generalization of this theorem for doubly stochastic tensors. Particularly, we prove that each permutation tensor is an extreme point of the set of doubly stochastic tensors, and the Birkhoff-von Neumann theorem holds for doubly stochastic tensors. Furthermore, an algorithm is proposed to find a convex combination of permutation tensors for any doubly stochastic tensor.}
}

